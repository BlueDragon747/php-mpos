# Local Config — global.inc.php is rendered by the deploy bundle from
# templates/ at install time and contains DB creds + RPC creds. Never
# track. (security.inc.php remains tracked — no secrets, just policy.)
/public/include/config/global.inc.php
#/public/include/config/security.inc.php

# Templates
/public/templates/compile/*.php
/public/templates/compile/**
/public/templates/cache/*.php
/public/templates/cache/**

# Logs
/cronjobs/**
/cronjobs/logs/**.txt
/cronjobs/logs/**.txt.*.gz
/logs/*
/mpos-25.2-go-deploy-*.log

# Test configs
public/include/config/global.inc.scrypt.php
public/include/config/global.inc.sha.php

# IDE Settings
/.idea/*
.buildpath
.project
.settings

# Vite build output (frontend/ produces this; build locally before deploy)
/public/v2/dist/

# /etc/logrotate.d/blakestream-mpos
#
# Retention policy for the MPOS pool stack. Operator-facing service and
# backup notes live in HELP.md. The deploy script installs these rules
# into /etc/logrotate.d/blakestream-mpos.
#
# Rule of thumb:
#   - Go Eloipool writes accepted shares to shares.log; keep it bounded
#     because the importer tracks offsets and handles copytruncate.
#   - PHP cron logs in /opt/blakestream-mpos/cronjobs/logs/<job>/
#     are daily-stamped by KLogger; bound individual files and age them out.
#   - mmp.log is the loud one during aux daemon sync; keep only one week.

# --- cronjobs-py + sse + nginx + deploy helpers -------------------------
/var/log/blakestream-mpos/cronjobs.stdout
/var/log/blakestream-mpos/cronjobs.stderr
/var/log/blakestream-mpos/sharelog-importer.stdout
/var/log/blakestream-mpos/sharelog-importer.stderr
/var/log/blakestream-mpos/sse.stdout
/var/log/blakestream-mpos/sse.stderr
/var/log/blakestream-mpos/nginx-access.log
/var/log/blakestream-mpos/nginx-error.log
/var/log/blakestream-mpos/backup.log
/var/log/blakestream-mpos/build-monitor.log
{
    daily
    rotate 7
    maxage 7
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}

# --- Go Eloipool share audit log ----------------------------------------
/var/log/blakestream-eliopool-25.2-go/shares.log {
    daily
    rotate 7
    maxage 7
    maxsize 100M
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}

# --- legacy eloipool share audit log ------------------------------------
/var/log/blakestream-mpos/pool/share-logfile {
    daily
    rotate 7
    maxage 7
    maxsize 100M
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}

# --- Go Eloipool pool logs ----------------------------------------------
/var/log/blakestream-mpos/pool/eloipool-go.log
/var/log/blakestream-mpos/pool/eloipool.stdout
/var/log/blakestream-mpos/pool/eloipool.stderr
{
    daily
    rotate 7
    maxage 7
    maxsize 100M
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}

# --- merged-mine-proxy ---------------------------------------------------
/var/log/blakestream-mpos/pool/mmp.log
/var/log/blakestream-mpos/pool/mergeminer.stdout
/var/log/blakestream-mpos/pool/mergeminer.stderr
{
    daily
    rotate 7
    maxage 7
    maxsize 100M
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}

# --- PHP cron per-job logs (KLogger writes log_<date>.txt per job) -----
# KLogger names files log_<YYYY-MM-DD>.txt so this bounds individual
# files in case any of them gets unusually large.
/opt/blakestream-mpos/cronjobs/logs/*/log_*.txt {
    weekly
    rotate 4
    maxage 30
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}

# /etc/mpos/mergeminer.env — env for mergeminer.service
# Install: sudo install -m 600 mergeminer.env.example /etc/mpos/mergeminer.env
# then edit /etc/mpos/mergeminer.env for your real RPC creds + aux addresses.

MMP_WORKER_PORT=9992
MMP_MERKLE_SIZE=16

# Parent chain RPC (Blakecoin mainnet).
MMP_PARENT_URL='http://poolrpc:replaceme@127.0.0.1:8772/'

# Aux chains — one `-x` + `-a` pair each, in order: Photon, BlakeBitcoin,
# Lithium, Electron-ELT, Universalmolecule. The payout address must be
# mainnet bech32 (or legacy) in the matching chain's HRP. The argument
# string is pasted literally so quoting rules are standard shell.
MMP_AUX_ARGS="
  -x 'http://poolrpc:replaceme@127.0.0.1:8984/' -a 'pho1......poolpayout'
  -x 'http://poolrpc:replaceme@127.0.0.1:8243/' -a 'bbtc1.....poolpayout'
  -x 'http://poolrpc:replaceme@127.0.0.1:12000/' -a 'lit1......poolpayout'
  -x 'http://poolrpc:replaceme@127.0.0.1:6852/' -a 'elt1......poolpayout'
  -x 'http://poolrpc:replaceme@127.0.0.1:5921/' -a 'umo1......poolpayout'
"
